# Minimum runtime
POSTGRES_URL=
BETTER_AUTH_SECRET=

# Vercel OAuth (required for sign-in)
NEXT_PUBLIC_VERCEL_APP_CLIENT_ID=
VERCEL_APP_CLIENT_SECRET=

# GitHub App (required for repo access, pushes, and PRs)
# Callback URL: {YOUR_ORIGIN}/api/auth/callback/github (better-auth)
# Setup URL:    {YOUR_ORIGIN}/api/github/app/callback (installation sync)
# In the GitHub App settings:
#   1. Use the GitHub App Client ID and Client Secret below
#   2. Make the app public if you want org installs to work cleanly
#   3. Store the private key either as PEM contents with escaped newlines
#      or as a base64-encoded PEM
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# Optional integrations
ELEVENLABS_API_KEY=

# Optional Redis / Vercel KV (skills metadata cache; falls back to in-memory when not set)
REDIS_URL=
KV_URL=

# Optional deployment refinements
# Set to "hobby" to use lower resource defaults for constrained deployments.
# Leave unset for standard behavior.
OPEN_AGENTS_RESOURCE_PROFILE=
VERCEL_PROJECT_PRODUCTION_URL=
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=
# Optional base snapshot for fresh sandboxes. If unset, sandboxes use Vercel's standard Sandbox runtime.
# Use a snapshot created in/accessible to your own Vercel scope.
VERCEL_SANDBOX_BASE_SNAPSHOT_ID=

# --- mcp-js (mcp-v8) JavaScript runtime ---
# Selects the mcp-js runtime and how per-session workers are spawned.
#   unset / "shared": every session uses the single MCP_JS_BASE_URL server.
#   "subprocess":      each session gets a local `mcp-v8` child process sharing
#                      an on-disk content-addressed store (local dev / self-host).
MCP_JS_WORKER_MODE=
# Shared mcp-v8 server URL (used in "shared" mode).
MCP_JS_BASE_URL=
# Path to the `mcp-v8` binary for subprocess mode (default: "mcp-v8" on PATH).
MCP_JS_BIN=
# Shared content-addressed store directory for subprocess workers (default: ".mcp-js").
MCP_JS_STORAGE_DIR=
# Launch subprocess workers with the bundled toolbox languages (picat, lua,
# craftos, …). Requires the assets present at MCP_JS_LANGUAGES_DIR (the web
# Dockerfile copies them to /opt/languages). "true" to enable.
MCP_JS_BUNDLED_LANGUAGES=
# Directory holding the bundled language wasm + bootstrap.js + rego policies
# (default: "/opt/languages").
MCP_JS_LANGUAGES_DIR=
# Persist per-session /work filesystem snapshots ("true" to enable).
MCP_JS_FS_SNAPSHOTS=
# S3-compatible bucket backing the shared filesystem blob store (e.g. MinIO).
# When unset, fs snapshots use a node-local dir under MCP_JS_STORAGE_DIR.
MCP_JS_S3_BUCKET=
# S3/MinIO credentials + endpoint the spawned workers read (MinIO needs the
# endpoint + path-style addressing).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=
AWS_S3_FORCE_PATH_STYLE=
AWS_REGION=
# Spawn a session's edited launch command verbatim ("true"). Off by default: the
# override runs an arbitrary process on the host. Trusted single-tenant only.
MCP_JS_ALLOW_COMMAND_OVERRIDE=
